{
  "name": "kimono-coordinator",
  "private": true,
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "run-p --aggregate-output check:{lint:withtype,format}",
    "check:lint": "oxlint",
    "check:lint:withtype": "oxlint --type-aware --type-check",
    "check:format": "oxfmt --check",
    "check:type": "tsgo -b",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "fix:lint": "oxlint --fix",
    "fix:format": "oxfmt --write"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@openai/codex": "^0.114.0",
    "@tanstack/router-plugin": "^1.166.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^27.4.0",
    "lefthook": "^2.1.4",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "shadcn": "^4.0.6",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@tailwindcss/vite": {
      "vite": "^8.0.0"
    }
  },
  "engines": {
    "npm": "please-use-pnpm"
  },
  "packageManager": "pnpm@10.32.1"
}
